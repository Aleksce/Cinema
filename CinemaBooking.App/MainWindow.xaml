<Window x:Class="CinemaBooking.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cinema Booking" Height="650" Width="980">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#17202A" Padding="12" CornerRadius="8">
            <DockPanel>
                <TextBlock Text="Онлайн-бронирование кинотеатра"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold"
                           DockPanel.Dock="Left" />
                <TextBlock Text="{Binding CurrentUserDisplay}"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="0,12,0,0">
            <TabItem Header="Авторизация">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Вход" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                        <TextBlock Text="Email" />
                        <TextBox Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="Пароль" />
                        <PasswordBox x:Name="LoginPasswordBox" Margin="0,0,0,8" />
                        <Button Content="Войти" Padding="10,6" Width="120" Click="Login_Click" />
                        <TextBlock Text="{Binding AuthMessage}" Foreground="DarkRed" Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Регистрация" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                        <TextBlock Text="Имя" />
                        <TextBox Text="{Binding RegisterName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="Email" />
                        <TextBox Text="{Binding RegisterEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="Пароль" />
                        <PasswordBox x:Name="RegisterPasswordBox" Margin="0,0,0,8" />
                        <Button Content="Создать аккаунт" Padding="10,6" Width="140" Click="Register_Click" />
                        <TextBlock Text="{Binding RegisterMessage}" Foreground="DarkGreen" Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Сеансы и места">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Сеанс:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Width="420"
                                  ItemsSource="{Binding Sessions}"
                                  DisplayMemberPath="DisplayTitle"
                                  SelectedItem="{Binding SelectedSession}" />
                        <Button Content="Обновить" Margin="8,0,0,0" Padding="10,6" Click="Refresh_Click" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DataGrid ItemsSource="{Binding Seats}"
                                  SelectedItem="{Binding SelectedSeat}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="0,0,12,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ряд" Binding="{Binding Row}" Width="*" />
                                <DataGridTextColumn Header="Место" Binding="{Binding Number}" Width="*" />
                                <DataGridCheckBoxColumn Header="Занято" Binding="{Binding IsBooked}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Действия" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                            <TextBlock Text="Выберите свободное место в таблице и нажмите кнопку ниже." TextWrapping="Wrap" />
                            <Button Content="Забронировать место" Padding="10,8" Margin="0,12,0,0" Click="BookSeat_Click" />
                            <TextBlock Text="{Binding BookingMessage}" Margin="0,12,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Мои брони">
                <Grid Margin="16">
                    <DataGrid ItemsSource="{Binding MyBookings}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Фильм" Binding="{Binding Session.MovieTitle}" Width="2*" />
                            <DataGridTextColumn Header="Начало" Binding="{Binding Session.StartsAt}" Width="*" />
                            <DataGridTextColumn Header="Ряд" Binding="{Binding Seat.Row}" Width="*" />
                            <DataGridTextColumn Header="Место" Binding="{Binding Seat.Number}" Width="*" />
                            <DataGridTextColumn Header="Дата брони" Binding="{Binding BookedAt}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
